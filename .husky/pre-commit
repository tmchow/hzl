# Verify pnpm-lock.yaml is in sync with package.json
pnpm install --frozen-lockfile --ignore-scripts 2>/dev/null || {
  echo "❌ pnpm-lock.yaml is out of sync with package.json"
  echo "   Run 'pnpm install' and commit the updated lock file."
  exit 1
}

pnpm lint:staged || {
  echo "❌ Staged TypeScript files failed ESLint"
  echo "   Run 'pnpm lint:fix' or review the staged changes and try again."
  exit 1
}
